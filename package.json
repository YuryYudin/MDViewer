{
  "name": "mdviewer",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:e2e": "cd src-tauri && cargo build --features e2e",
    "pretest:e2e": "npm run build:e2e",
    "test:e2e": "wdio run wdio.conf.ts",
    "gen:types": "cd src-tauri && cargo run --bin export_types --quiet",
    "predev": "npm run gen:types",
    "prebuild": "npm run gen:types",
    "build:dmg": "tauri build --bundles dmg",
    "build:msi": "tauri build --bundles msi",
    "build:appimage": "tauri build --bundles appimage",
    "build:deb": "tauri build --bundles deb",
    "build:debug": "tauri build --debug",
    "package": "./scripts/build.sh",
    "package:debug": "./scripts/build.sh --debug",
    "package:skip-tests": "./scripts/build.sh --skip-tests"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/json-reporter": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "expect-webdriverio": "^5.0.0",
    "jsdom": "^25.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "webdriverio": "^9.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "mermaid": "^11.0.0"
  }
}
