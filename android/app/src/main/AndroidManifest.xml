<?xml version="1.0" encoding="utf-8"?>
<!--
  Single-activity Compose host. Intent filters here cover the
  "open from external app" surface (Drive, Gmail attachment, Files,
  third-party file managers). The complementary ACTION_OPEN_DOCUMENT
  chooser is fired *outbound* from MainActivity in Phase C5 — that is
  how the in-app "Open file" FAB hands off to the system picker — and
  doesn't need a manifest filter.

  ACTION_SEND ("share to MDViewer") is wired in E3:
  [ShareIntents.extractDocumentUri] pulls EXTRA_STREAM out of the
  inbound intent and [IntentDispatcher] routes the result through the
  same NavDestination.Document path ACTION_VIEW uses. Two SEND filters
  declared below — text/markdown for clean producers, and *.md +
  text/* / */* for the long tail of share producers that don't tag
  their MIME correctly.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Mdviewer"
        android:requestLegacyExternalStorage="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">

            <!-- Standard launcher entry point. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              ACTION_VIEW for explicit text/markdown MIME. This is the
              clean path Drive uses when it knows the file is markdown
              (matches the `MarkdownFiles` SAF predicate the design
              spec expects in Phase C).
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="text/markdown" />
            </intent-filter>

            <!--
              Path-pattern fallback for providers that hand us
              `application/octet-stream` or `*/*` plus a filename ending
              in .md / .markdown. Many file-manager apps and cloud
              providers don't actually report text/markdown for .md
              files (the IANA registration is recent), so this catch-all
              keeps the open-from-Drive flow working in practice.

              `pathPattern` glob: `.*\\.md` matches any path ending in
              `.md`. The double-backslash is XML-escaped from a single
              backslash that the manifest parser then escapes for the
              regex engine. Order matters: the more specific .markdown
              pattern goes after .md so the framework's pattern matcher
              evaluates them top-down without ambiguity.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="*/*" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.md" />
                <data android:pathPattern=".*\\.markdown" />
            </intent-filter>

            <!--
              ACTION_SEND clean path: producers that tag the share with
              `text/markdown`. This is the same MIME the desktop builds
              produce when handing files to the system file manager;
              we accept it directly so a Drive "Share with..." action
              that knows the MIME hits this filter and skips the *./*
              fallback below.
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/markdown" />
            </intent-filter>

            <!--
              ACTION_SEND fallback for the wider text/* surface: most
              cloud providers (Drive especially) tag .md files as
              `text/*` or `*/*` rather than the still-recent
              `text/markdown` IANA registration. Same pathPattern logic
              as the ACTION_VIEW fallback above keeps the filter from
              advertising MDViewer for arbitrary text shares — only
              ones whose URI path ends in `.md` / `.markdown` will
              match. The framework runs the pathPattern check only when
              the MIME match passes AND the URI carries a path; share
              intents that hand us inline EXTRA_TEXT (no URI) won't
              match either filter, which is the right outcome
              (ShareIntents.extractDocumentUri returns null on those
              and the dispatcher falls through to the cold-start
              default).
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
                <data android:mimeType="*/*" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.md" />
                <data android:pathPattern=".*\\.markdown" />
            </intent-filter>
        </activity>
    </application>

</manifest>
