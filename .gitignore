# Build artifacts
/target/
**/target/
/dist/
**/dist/
node_modules/
coverage/

# Tauri
src-tauri/target/
src-tauri/gen/

# ts-rs auto-emits per-type .ts files under `bindings/` when running
# `cargo test`. Our pipeline uses the `export_types` binary instead, which
# writes to `src/types-generated.ts`, so the bindings/ directory is noise.
# A6 split RenderOptions/RenderResult into mdviewer-core, which gets its
# own auto-emitted bindings/ for the same reason.
src-tauri/bindings/
crates/mdviewer-core/bindings/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Worktrees / tcoder transient state (kept locally per-author)
.claude/worktrees/
.claude/tcoder/
Screenshot*.png

# A2: workspace + coverage
/target
/coverage.lcov
crates/*/target

# Android
android/.gradle/
android/build/
android/app/build/
android/core/build/
android/local.properties
android/captures/
android/.idea/
*.hprof
.cxx/

# C4: document.css is a build-time copy of crates/mdviewer-core/assets/
# document.css produced by the `copyCoreCss` Gradle task that runs before
# `preBuild`. Ignoring it keeps the canonical file at the workspace-crate
# path and prevents the two from drifting via stray edits to the copied
# version. The Gradle task re-creates it on every build.
android/app/src/main/assets/document.css

# Stray coverage lcov files generated by ad-hoc check-coverage.sh runs
/coverage-*.lcov

# C2: Playwright html-reporter and per-failure artifact directories.
# The reporter targets `outputFolder: 'test-results-html'` (relative to
# the playwright.config.ts testDir, i.e. e2e-visual/); the framework also
# writes failure traces/diffs under `test-results/`. Baselines live in
# e2e-visual/baselines/linux/ and ARE checked in (C3 owns those PNGs).
e2e-visual/test-results-html/
e2e-visual/test-results/

# C3: the gallery-page Vite build output is derived from sources under
# e2e-visual/gallery-page/ and the A1 fixture, and is regenerated by
# `npm run build:visual` (which `preview:visual` runs before serving).
# The `dist/` global rule above (`**/dist/`) already covers this path,
# but it lands here too as an explicit, grep-friendly entry so the
# rationale for the visual layer is co-located with its siblings.
e2e-visual/gallery-page/dist/

# D1: v0.4.0 audit transient state. `scripts/audit-v040.mjs` materializes
# the v0.4.0 tag in a dedicated `git worktree add` under
# `.audit-worktrees/v0.4.0-<pid>/` and runs `cargo build` against it; the
# script's try/finally cleanup tears the path down on success, but the
# ignore rule is belt-and-suspenders so a crash mid-run doesn't leak a
# worktree into `git status`. D1 lands this rule alongside the script so
# D2's first invocation already has the protection in place.
.audit-worktrees/
